rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && userDoc().role == 'admin';
    }

    function isOrganizer() {
      return isSignedIn() && userDoc().role == 'organizer';
    }

    function isController() {
      return isSignedIn() && userDoc().role == 'controller';
    }

    function isStaff() {
      return isAdmin() || isOrganizer() || isController();
    }

    function isEventOrganizer(eventId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid;
    }

    function accountIsActive() {
      return !('accountStatus' in userDoc()) || userDoc().accountStatus == 'active';
    }

    // Utilisateurs
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'accountStatus'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Événements
    match /events/{eventId} {
      allow read: if resource.data.status == 'published' ||
        (isSignedIn() && (
          resource.data.organizerId == request.auth.uid ||
          isAdmin()
        ));
      allow create: if isSignedIn() && isOrganizer() && accountIsActive() &&
        request.resource.data.organizerId == request.auth.uid &&
        request.resource.data.status in ['draft', 'pending'];
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.organizerId == request.auth.uid && isOrganizer() && accountIsActive() &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['featured', 'commissionTotal', 'rejectionReason']) &&
          (request.resource.data.status == resource.data.status ||
           request.resource.data.status in ['draft', 'pending'])) ||
        (resource.data.status == 'published' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['placesLeft', 'soldTickets', 'revenue', 'commissionTotal', 'ticketTypes', 'updatedAt']) &&
          request.resource.data.placesLeft >= 0 &&
          request.resource.data.placesLeft < resource.data.placesLeft &&
          request.resource.data.soldTickets > resource.data.soldTickets &&
          request.resource.data.revenue >= resource.data.revenue)
      );
      allow delete: if isSignedIn() && (
        resource.data.organizerId == request.auth.uid ||
        isAdmin()
      );
    }

    // Catégories
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isSignedIn() && (isOrganizer() || isAdmin()) && accountIsActive();
      allow update, delete: if isAdmin();
    }

    // Billets
    match /tickets/{ticketId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isStaff()
      );
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'valid';
      allow update: if isSignedIn() && (
        isOrganizer() || isAdmin() || isController() ||
        (resource.data.userId == request.auth.uid &&
         resource.data.status == 'valid' &&
         request.resource.data.userId != request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'userName', 'userEmail', 'transferredAt', 'transferredFrom']))
      );
    }

    // Achats
    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        (isOrganizer() && isEventOrganizer(resource.data.eventId))
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Liste d'attente
    match /waitlist/{entryId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        (isOrganizer() && isEventOrganizer(resource.data.eventId))
      );
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        isAdmin() ||
        (isOrganizer() && isEventOrganizer(resource.data.eventId))
      );
    }

    // Logs d'entrée (scan)
    match /entryLogs/{logId} {
      allow read: if isSignedIn() && (
        isStaff() ||
        (isOrganizer() && isEventOrganizer(resource.data.eventId))
      );
      allow create: if isSignedIn() && isStaff();
    }

    // Notifications organisateur (email/SMS/push simulés)
    match /eventNotifications/{notifId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (isOrganizer() && isEventOrganizer(resource.data.eventId))
      );
      allow create: if isSignedIn() && (
        isAdmin() ||
        (isOrganizer() && isEventOrganizer(request.resource.data.eventId))
      );
    }

    // Favoris
    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Transferts de billets
    match /ticketTransfers/{transferId} {
      allow read: if isSignedIn() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
    }

    // Alertes événements
    match /eventAlerts/{alertId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Tickets support
    match /supportTickets/{ticketId} {
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid) ||
        request.resource.data.userId == null;
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }
  }
}
