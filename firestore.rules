rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Utilisateurs — lecture publique limitée, écriture par le propriétaire ou admin
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Événements — lecture publique si publié, CRUD pour organisateur propriétaire ou admin
    match /events/{eventId} {
      allow read: if resource.data.status == 'published' ||
        (request.auth != null && (
          resource.data.organizerId == request.auth.uid ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        ));
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['organizer', 'admin'];
      allow update: if request.auth != null && (
        resource.data.organizerId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        // Achat de billet : décrémenter places et mettre à jour les stats uniquement
        (
          resource.data.status == 'published' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['placesLeft', 'soldTickets', 'revenue']) &&
          request.resource.data.placesLeft >= 0 &&
          request.resource.data.placesLeft < resource.data.placesLeft &&
          request.resource.data.soldTickets > resource.data.soldTickets &&
          request.resource.data.revenue >= resource.data.revenue
        )
      );
      allow delete: if request.auth != null && (
        resource.data.organizerId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Catégories — lecture publique, création par organisateur/admin
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['organizer', 'admin'];
      allow update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Billets — lecture par propriétaire, organisateur de l'événement, ou admin
    match /tickets/{ticketId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['organizer', 'admin']
      );
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'valid';
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['organizer', 'admin'];
    }

    // Achats — lecture par propriétaire
    match /purchases/{purchaseId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
